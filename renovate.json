{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:recommended",
    "customManagers:biomeVersions"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "before 5am every weekday",
    "every weekend"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "postUpdateOptions": ["pnpmDedupe"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "before 5am on monday"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "github-actions",
      "automerge": true
    },
    {
      "matchManagers": ["docker-compose", "dockerfile"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "docker",
      "automerge": true
    },
    {
      "matchManagers": ["pep621", "pip_requirements"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "python",
      "automerge": true
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "node",
      "automerge": true
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "rust",
      "automerge": true
    },
    {
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "pre-commit",
      "automerge": true
    },
    {
      "groupName": "testing",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "matchPackageNames": [
        "/pytest/",
        "/cypress/",
        "/pretty_assertions/",
        "/testcontainers_modules/",
        "/testcontainers/"
      ]
    },
    {
      "groupName": "rust-stable",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "matchPackageNames": [
        "/serde/",
        "/base64/",
        "/tracing/",
        "/rustls/",
        "/tokio/",
        "/regex/",
        "/reqwest/"
      ]
    },
    {
      "groupName": "linting",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "matchPackageNames": [
        "/@biomejs/biome/",
        "/pre-commit/",
        "/postcss/",
        "/ruff/",
        "/pretty_assertions/",
        "/pre-commit/",
        "/mypy/",
        "/sourcery/",
        "/@types/.*/",
        "/types-.*/",
        "/scss/",
        "/openapi-typescript/"
      ]
    },
    {
      "groupName": "temporary-debump1",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "matchPackageNames": [
        "/@nuxt/content/"
      ]
    },
    {
      "groupName": "temporary-debump3",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": true,
      "matchPackageNames": [
        "/polars/"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "pnpm-ignore-non-major",
      "enabled": false,
      "matchPackageNames": [
        "/pnpm/"
      ]
    },
    {
      "groupName": "maplibre",
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "automerge": false,
      "matchPackageNames": [
        "/maplibre-gl/",
        "/maplibre-gl-indoor/"
      ]
    },
    {
      "description": "A breaking change is reviewed on its own: never grouped with an unrelated one, and never automerged. Renovate's monorepo presets still keep packages that must move in lockstep (@nuxt/*, @fullcalendar/*, ...) in one PR, since those are a single logical upgrade.",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
