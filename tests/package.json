{
  "name": "@navigatum/e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for NavigaTUM using Playwright",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api-tests",
    "test:ui": "playwright test --project=ui-tests-chromium",
    "test:ui:chromium": "playwright test --project=ui-tests-chromium",
    "test:ui:headed": "playwright test --project=ui-tests-chromium --headed",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:interactive": "playwright test --ui",
    "test:report": "playwright show-report",
    "update-screenshots": "playwright test --project=ui-tests-chromium --update-snapshots",
    "docker:up": "docker compose -f ../compose.local.yml up -d",
    "docker:down": "docker compose -f ../compose.local.yml down",
    "docker:logs": "docker compose -f ../compose.local.yml logs -f"
  },
  "keywords": [
    "e2e",
    "playwright",
    "testing",
    "navigatum"
  ],
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/geojson": "^7946.0.16",
    "@types/geojson-vt": "^3.2.5",
    "@types/node": "^22.10.2",
    "geojson-vt": "^4.0.3",
    "typescript": "^5.7.2",
    "vt-pbf": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.3.0"
}
