{
	"name": "navigatum",
	"private": true,
	"scripts": {
		"dev": "nuxt dev",
		"build": "nuxt build",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"type-check": "nuxt typecheck",
		"type-refresh": "openapi-typescript ../openapi.yaml --output app/api_types/index.ts --export-type --immutable --array-length && pnpm run format && pnpm run lint && pnpm run type-check",
		"lint": "biome lint --write --error-on-warnings . ",
		"format": "biome format --write && biome check --formatter-enabled=false --linter-enabled=false --write",
		"test": "vitest run"
	},
	"dependencies": {
		"@fullcalendar/vue3": "7.0.1",
		"@googlemaps/polyline-codec": "1.0.28",
		"@headlessui/vue": "1.7.23",
		"@mdi/js": "^7.4.47",
		"@nuxt/content": "3.15.0",
		"@nuxt/image": "2.0.0",
		"@nuxtjs/color-mode": "4.0.1",
		"@vueuse/core": "14.3.0",
		"@vueuse/nuxt": "14.3.0",
		"@vueuse/router": "14.3.0",
		"better-sqlite3": "12.11.1",
		"maplibre-gl": "6.0.0-22",
		"nuxt": "4.5.0",
		"opening_hours": "^3.13.0",
		"prom-client": "^15.1.3",
		"sharp": "0.35.3",
		"temporal-polyfill": "1.0.1",
		"ts-essentials": "^10.1.1",
		"vue": "3.5.40",
		"vue-router": "5.2.0",
		"vue3-carousel": "0.17.0",
		"zod": "^4.4.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@nuxtjs/i18n": "10.5.0",
		"@nuxtjs/tailwindcss": "7.0.0-beta.1",
		"@types/geojson": "7946.0.16",
		"@vue/tsconfig": "0.9.1",
		"openapi-typescript": "7.13.0",
		"tailwindcss": "4.3.3",
		"typescript": "7.0.2",
		"vitest": "4.1.10",
		"vue-tsc": "3.3.7"
	},
	"type": "module",
	"packageManager": "pnpm@11.3.0"
